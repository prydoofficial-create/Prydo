<p>pragma solidity ^0.8.20;</p>
<p><br></p>
<p>import &quot;@openzeppelin/contracts/token/ERC721/ERC721.sol&quot;;</p>
<p><br></p>
<p>contract PrydoID is ERC721 {</p>
<p><br></p>
<p>&nbsp; &nbsp; uint256 public tokenId;</p>
<p><br></p>
<p>&nbsp; &nbsp; mapping(address =&gt; bool) public minted;</p>
<p><br></p>
<p>&nbsp; &nbsp; constructor() ERC721(&quot;Prydo ID&quot;,&quot;PRYDOID&quot;){}</p>
<p><br></p>
<p>&nbsp; &nbsp; function mint() public {</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; require(!minted[msg.sender],&quot;Already minted&quot;);</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; tokenId++;</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; _safeMint(msg.sender,tokenId);</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; minted[msg.sender]=true;</p>
<p>&nbsp; &nbsp; }</p>
<p><br></p>
<p>&nbsp; &nbsp; function _beforeTokenTransfer(</p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; address from,</p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; address to,</p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; uint256 id,</p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; uint256 batch</p>
<p>&nbsp; &nbsp; ) internal override {</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; require(from==address(0),&quot;Soulbound&quot;);</p>
<p><br></p>
<p>&nbsp; &nbsp; &nbsp; &nbsp; super._beforeTokenTransfer(from,to,id,batch);</p>
<p>&nbsp; &nbsp; }</p>
<p>}</p>
